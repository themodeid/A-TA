-- Tabel periode (cut-off tanggal 16)
CREATE TABLE IF NOT EXISTS tb_periode (
    id_periode SERIAL PRIMARY KEY,
    bulan_gaji VARCHAR(20) NOT NULL,      -- contoh: 'April 2025'
    tanggal_awal DATE NOT NULL,
    tanggal_akhir DATE NOT NULL,
    status VARCHAR(20) DEFAULT 'aktif',   -- aktif, ditutup
    created_at TIMESTAMP DEFAULT NOW()
);

-- Tabel pegawai (data master, asumsi sudah ada/diisi Admin)
CREATE TABLE IF NOT EXISTS tb_pegawai (
    id_pegawai VARCHAR(10) PRIMARY KEY,   -- contoh: 'PGW001'
    nama_lengkap VARCHAR(100) NOT NULL,
    jabatan VARCHAR(50) NOT NULL,
    status VARCHAR(30) NOT NULL,          -- Guru Tetap, Karyawan Tetap, dst
    jenis_kelamin CHAR(1),
    no_hp VARCHAR(20),
    email VARCHAR(100)
);

-- Tabel absensi: hasil parsing dari Excel export fingerprint
CREATE TABLE IF NOT EXISTS tb_absensi (
    id_absen SERIAL PRIMARY KEY,
    id_periode INTEGER NOT NULL REFERENCES tb_periode(id_periode),
    id_pegawai VARCHAR(10) NOT NULL REFERENCES tb_pegawai(id_pegawai),
    tanggal DATE NOT NULL,
    status_kehadiran VARCHAR(20) NOT NULL CHECK (status_kehadiran IN ('Hadir', 'Izin', 'Sakit', 'Alpha')),
    keterangan TEXT,
    created_at TIMESTAMP DEFAULT NOW(),
    UNIQUE (id_pegawai, tanggal)          -- cegah duplikat: 1 pegawai 1 tanggal cuma 1 record
);

-- Tabel log upload: jejak audit setiap kali file di-upload
CREATE TABLE IF NOT EXISTS tb_upload_log (
    id_upload SERIAL PRIMARY KEY,
    id_periode INTEGER REFERENCES tb_periode(id_periode),
    nama_file VARCHAR(255),
    total_baris INTEGER,
    baris_sukses INTEGER,
    baris_gagal INTEGER,
    detail_error JSONB,
    uploaded_at TIMESTAMP DEFAULT NOW()
);