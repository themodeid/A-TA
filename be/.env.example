# Salin ke be/.env untuk development lokal (npm run dev di folder be/)
# Nilai harus selaras dengan .env di root project.

NODE_ENV=development
PORT=3020
APP_PUBLIC_HOST=localhost
DATABASE_URL=postgresql://postgres:change-me@localhost:5436/kontakdb-reading1
REDIS_URL=redis://localhost:6386
CORS_ORIGIN=http://localhost:3021
JSON_BODY_LIMIT=10kb
STARTUP_RETRIES=30
STARTUP_DELAY_MS=2000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DB_WAIT_ATTEMPTS=30
