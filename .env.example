# =============================================================================
# Salin file ini ke .env di root project, lalu sesuaikan nilainya.
#   cp .env.example .env
# Untuk dev lokal tanpa Docker, salin juga:
#   cp .env.example be/.env
#   cp fe/.env.example fe/.env.local
# =============================================================================

NODE_ENV=development

# --- Ports (host) ---
BACKEND_PORT=3030
FRONTEND_PORT=3031
POSTGRES_PORT=5438
# REDIS_PORT=6388

# --- Host labels (untuk log & URL publik) ---
APP_PUBLIC_HOST=localhost
FRONTEND_PUBLIC_HOST=localhost

# --- PostgreSQL ---
POSTGRES_DB=kontakdb-reading1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# --- Backend (local / be/.env) ---
PORT=3020
DATABASE_URL=postgresql://postgres:change-me@localhost:5436/kontakdb-reading1
# REDIS_URL=redis://localhost:6386
CORS_ORIGIN=http://localhost:3021
JSON_BODY_LIMIT=10kb
STARTUP_RETRIES=30
STARTUP_DELAY_MS=2000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DB_WAIT_ATTEMPTS=30

# --- Backend (Docker internal — dipakai docker-compose) ---
DATABASE_URL_DOCKER=postgresql://postgres:change-me@postgres:5432/kontakdb-reading1
# REDIS_URL_DOCKER=redis://redis:6379

# --- API ---
API_KONTAK_PATH=/api/kontak
BACKEND_INTERNAL_HOST=backend

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3020/api/kontak
INTERNAL_API_URL=http://backend:3020/api/kontak

# --- Docker (file watching di Windows) ---
WATCHPACK_POLLING=false
CHOKIDAR_USEPOLLING=false

# --- Docker service names (container_name) ---
POSTGRES_CONTAINER_NAME=postgres-reading-1
# REDIS_CONTAINER_NAME=redis-reading-1
BACKEND_CONTAINER_NAME=backend-reading-1
FRONTEND_CONTAINER_NAME=frontend-reading-1
